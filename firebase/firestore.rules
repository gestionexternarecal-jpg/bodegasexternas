rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Desarrollo: reemplazar por auth.uid antes de produccion.
    match /warehouse_profiles/{id} {
      allow read, write: if false;
    }
    match /bin_locations/{id} {
      allow read, write: if false;
    }
    match /bin_stock/{id} {
      allow read, write: if false;
    }
  }
}
